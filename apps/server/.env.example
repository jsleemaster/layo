# Purpose: keep filesystem authorization as the local-first default.
LAYO_LIBRARY_REGISTRY_MEMBERS_FILE=
LAYO_LIBRARY_REGISTRY_MEMBERS=

# Purpose: enable team-owned shared authorization only when both values are set.
# Run authorization:migrate with a migration role before starting the runtime role.
LAYO_AUTHORIZATION_DATABASE_URL=
LAYO_AUTHORIZATION_SHARED_SCOPE=

# Purpose: rotate the MCP principal without restarting the MCP process.
LAYO_MCP_USER_ID=
LAYO_MCP_MEMBER_TOKEN_FILE=
LAYO_MCP_MEMBER_TOKEN=
