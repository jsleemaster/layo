{
  "name": "@layo/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm --filter @layo/renderer build && pnpm --filter @layo/collaboration build && tsc -p tsconfig.json && vite build",
    "dev": "vite --host 127.0.0.1",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@layo/collaboration": "workspace:*",
    "@layo/renderer": "workspace:*",
    "@vitejs/plugin-react": "^5.0.0",
    "konva": "^10.0.0",
    "lib0": "^0.2.114",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-konva": "^19.0.0",
    "vite": "^7.0.0",
    "y-indexeddb": "^9.0.12",
    "y-protocols": "^1.0.7",
    "y-websocket": "^3.0.0",
    "yjs": "^13.6.27"
  },
  "devDependencies": {
    "fake-indexeddb": "^6.2.5",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "typescript": "^5.0.0",
    "vitest": "^3.0.0"
  }
}
